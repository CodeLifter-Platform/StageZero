@page "/identity/forgot-password"
@using Lifted.BlazorAuth.AspNetIdentity.Services
@using System.ComponentModel.DataAnnotations
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Forgot Password</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Class="mr-2" />
            Forgot Password
        </MudText>

        @if (!_emailSent)
        {
            <MudText Typo="Typo.body1" Class="mb-4">
                Enter your email address and we'll send you a link to reset your password.
            </MudText>

            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_model.Email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Required="true"
                              RequiredError="Email is required"
                              InputType="InputType.Email"
                              For="@(() => _model.Email)"
                              Class="mb-4" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send Reset Link</span>
                    }
                </MudButton>
            </EditForm>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">
                    @_errorMessage
                </MudAlert>
            }
        }
        else
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                <MudText Typo="Typo.body1">
                    If an account exists with that email address, we've sent a password reset link.
                    Please check your email.
                </MudText>
            </MudAlert>

            <MudText Typo="Typo.body2" Class="mb-4">
                Didn't receive the email? Check your spam folder or try again.
            </MudText>

            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       OnClick="@(() => _emailSent = false)">
                Try Again
            </MudButton>
        }

        <MudDivider Class="my-4" />

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="@(() => Navigation.NavigateTo("/identity/login"))">
            Back to Login
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private ForgotPasswordModel _model = new();
    private bool _isLoading = false;
    private bool _emailSent = false;
    private string? _errorMessage;

    private class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string Email { get; set; } = string.Empty;
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await AuthService.SendPasswordResetTokenAsync(_model.Email);

            // Always show success message for security (don't reveal if email exists)
            _emailSent = true;
            Snackbar.Add("Password reset email sent", Severity.Success);
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}

