@page "/identity/account/profile"
@using Lifted.BlazorAuth.AspNetIdentity.Services
@using Lifted.BlazorAuth.AspNetIdentity.Models
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@inject IAuthService AuthService
@inject UserManager<ApplicationUser> UserManager
@inject ISnackbar Snackbar

<PageTitle>My Profile</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" Class="mr-2" />
        My Profile
    </MudText>

    <MudGrid>
        <!-- Profile Information -->
        <MudItem xs="12" md="6">
            <MudPaper Elevation="2" Class="pa-6">
                <MudText Typo="Typo.h5" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="mr-2" />
                    Profile Information
                </MudText>

                @if (_currentUser != null)
                {
                    <EditForm Model="@_profileModel" OnValidSubmit="HandleUpdateProfile">
                        <DataAnnotationsValidator />

                        <MudTextField @bind-Value="_profileModel.FirstName"
                                      Label="First Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      For="@(() => _profileModel.FirstName)"
                                      Class="mb-4" />

                        <MudTextField @bind-Value="_profileModel.LastName"
                                      Label="Last Name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      For="@(() => _profileModel.LastName)"
                                      Class="mb-4" />

                        <MudTextField Value="@_currentUser.Email"
                                      Label="Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Disabled="true"
                                      HelperText="Use 'Change Email' section to update"
                                      Class="mb-4" />

                        <MudText Typo="Typo.body2" Class="mb-2">
                            Account created: @_currentUser.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                        </MudText>

                        @if (_currentUser.LastLoginAt.HasValue)
                        {
                            <MudText Typo="Typo.body2" Class="mb-4">
                                Last login: @_currentUser.LastLoginAt.Value.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
                            </MudText>
                        }

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@_isUpdatingProfile">
                            @if (_isUpdatingProfile)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Updating...</span>
                            }
                            else
                            {
                                <span>Update Profile</span>
                            }
                        </MudButton>
                    </EditForm>

                    @if (!string.IsNullOrEmpty(_profileError))
                    {
                        <MudAlert Severity="Severity.Error" Class="mt-4">
                            @_profileError
                        </MudAlert>
                    }
                }
            </MudPaper>
        </MudItem>

        <!-- Security Settings -->
        <MudItem xs="12" md="6">
            <MudStack Spacing="4">
                <!-- Change Password -->
                <ChangePassword />

                <!-- Change Email -->
                <ChangeEmail />

                <!-- Two-Factor Authentication -->
                <TwoFactorSetup />
            </MudStack>
        </MudItem>

        <!-- Roles and Permissions -->
        <MudItem xs="12">
            <MudPaper Elevation="2" Class="pa-6">
                <MudText Typo="Typo.h5" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Class="mr-2" />
                    Roles and Permissions
                </MudText>

                @if (_userRoles != null && _userRoles.Any())
                {
                    <MudStack Row="true" Spacing="2">
                        @foreach (var role in _userRoles)
                        {
                            <MudPaper Class="pa-2 d-flex align-center" Elevation="1">
                                <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                <MudText Typo="Typo.body2">@role</MudText>
                            </MudPaper>
                        }
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        No roles assigned
                    </MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private ApplicationUser? _currentUser;
    private ProfileModel _profileModel = new();
    private List<string>? _userRoles;
    private bool _isUpdatingProfile = false;
    private string? _profileError;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserData();
    }

    private async Task LoadUserData()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
        if (_currentUser != null)
        {
            _profileModel.FirstName = _currentUser.FirstName ?? string.Empty;
            _profileModel.LastName = _currentUser.LastName ?? string.Empty;
            _userRoles = (await AuthService.GetUserRolesAsync(_currentUser)).ToList();
        }
    }

    private class ProfileModel
    {
        [Required(ErrorMessage = "First name is required")]
        [StringLength(100, ErrorMessage = "First name cannot exceed 100 characters")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required")]
        [StringLength(100, ErrorMessage = "Last name cannot exceed 100 characters")]
        public string LastName { get; set; } = string.Empty;
    }

    private async Task HandleUpdateProfile()
    {
        _isUpdatingProfile = true;
        _profileError = null;

        try
        {
            if (_currentUser == null)
            {
                _profileError = "You must be logged in";
                return;
            }

            _currentUser.FirstName = _profileModel.FirstName;
            _currentUser.LastName = _profileModel.LastName;

            var result = await UserManager.UpdateAsync(_currentUser);

            if (result.Succeeded)
            {
                Snackbar.Add("Profile updated successfully", Severity.Success);
                await LoadUserData(); // Refresh user data
            }
            else
            {
                _profileError = string.Join(", ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            _profileError = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isUpdatingProfile = false;
        }
    }
}
