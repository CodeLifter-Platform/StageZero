@using Lifted.BlazorAuth.AspNetIdentity.Services
@using Lifted.BlazorAuth.AspNetIdentity.Models
@using System.ComponentModel.DataAnnotations
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<MudPaper Elevation="2" Class="pa-6">
    <MudText Typo="Typo.h5" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Email" Class="mr-2" />
        Change Email Address
    </MudText>

    @if (_currentUser != null)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            Current email: <strong>@_currentUser.Email</strong>
        </MudAlert>
    }

    <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <MudTextField @bind-Value="_model.NewEmail"
                      Label="New Email Address"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Required="true"
                      RequiredError="Email is required"
                      InputType="InputType.Email"
                      For="@(() => _model.NewEmail)"
                      Class="mb-4" />

        <MudTextField @bind-Value="_model.Password"
                      Label="Current Password"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Required="true"
                      RequiredError="Password is required for verification"
                      InputType="InputType.Password"
                      For="@(() => _model.Password)"
                      HelperText="Enter your password to confirm this change"
                      Class="mb-4" />

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@_isLoading">
            @if (_isLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Updating...</span>
            }
            else
            {
                <span>Update Email</span>
            }
        </MudButton>
    </EditForm>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">
            @_errorMessage
        </MudAlert>
    }
</MudPaper>

@code {
    private ChangeEmailModel _model = new();
    private ApplicationUser? _currentUser;
    private bool _isLoading = false;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private class ChangeEmailModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string NewEmail { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            if (_currentUser == null)
            {
                _errorMessage = "You must be logged in to change your email";
                return;
            }

            // Note: The current implementation doesn't verify password
            // You may want to add password verification before updating email
            var result = await AuthService.UpdateEmailAsync(_model.NewEmail);

            if (result)
            {
                Snackbar.Add("Email updated successfully. Please check your new email to verify it.", Severity.Success);
                _model = new(); // Reset form
                _currentUser = await AuthService.GetCurrentUserAsync(); // Refresh user
            }
            else
            {
                _errorMessage = "Failed to update email. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}

