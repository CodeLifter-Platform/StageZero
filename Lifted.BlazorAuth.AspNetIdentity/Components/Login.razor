@page "/identity/login"
@using Lifted.BlazorAuth.AspNetIdentity.Services
@using Lifted.BlazorAuth.AspNetIdentity.Models
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Login</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Class="mr-2" />
            Login
        </MudText>

        <EditForm Model="@_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_model.Email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Required="true"
                          RequiredError="Email is required"
                          InputType="InputType.Email"
                          Class="mb-4" />

            <MudTextField @bind-Value="_model.Password"
                          Label="Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Required="true"
                          RequiredError="Password is required"
                          InputType="InputType.Password"
                          Class="mb-4" />

            <MudCheckBox @bind-Value="_model.RememberMe"
                         Label="Remember me"
                         Color="Color.Primary"
                         Class="mb-4" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Logging in...</span>
                }
                else
                {
                    <span>Login</span>
                }
            </MudButton>
        </EditForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">
                @_errorMessage
            </MudAlert>
        }

        <MudDivider Class="my-4" />

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="@(() => Navigation.NavigateTo("/identity/forgot-password"))">
            Forgot Password?
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private LoginModel _model = new();
    private bool _isLoading = false;
    private string? _errorMessage;

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; } = false;
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await AuthService.LoginAsync(_model.Email, _model.Password, _model.RememberMe);

            if (result.Success)
            {
                Snackbar.Add($"Welcome back!", Severity.Success);

                // Redirect to return URL or home
                var redirectUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
                Navigation.NavigateTo(redirectUrl);
            }
            else if (result.RequiresTwoFactor)
            {
                Snackbar.Add("Two-factor authentication required", Severity.Info);
                Navigation.NavigateTo($"/identity/two-factor?returnUrl={ReturnUrl}");
            }
            else if (result.IsLockedOut)
            {
                _errorMessage = "Your account has been locked out. Please try again later.";
            }
            else if (result.IsNotAllowed)
            {
                _errorMessage = "You are not allowed to sign in. Please verify your email address.";
            }
            else
            {
                _errorMessage = result.ErrorMessage ?? "Login failed";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}

