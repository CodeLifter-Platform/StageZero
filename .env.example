# ═══════════════════════════════════════════════════════════════
# StageZero Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and update values for your environment
# DO NOT commit .env to source control

# ═══════════════════════════════════════════════════════════════
# DATABASE (SQLite)
# ═══════════════════════════════════════════════════════════════
# SQLite database path (used in Docker)
DATABASE_PATH=/app/data/stagezero.db

# ═══════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════
ASPNETCORE_ENVIRONMENT=Development

# HTTPS CERTIFICATE (Docker only)
# ═══════════════════════════════════════════════════════════════
# Password for the HTTPS certificate (.volumes/https/aspnetapp.pfx)
# See .volumes/https/README.md for certificate setup instructions
CERT_PASSWORD=STRONG_PASSWORD

# ═══════════════════════════════════════════════════════════════
# EMAIL (SMTP)
# ═══════════════════════════════════════════════════════════════
# SMTP server configuration for sending verification emails
# Leave empty to disable email sending (codes will be logged instead)
#
# For Gmail:
# 1. Enable 2-factor authentication on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password (not your regular password) below
#
# Note: Use double underscores (__) for nested configuration
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUsername=your-email@gmail.com
Email__SmtpPassword=your-app-password
Email__FromEmail=your-email@gmail.com
Email__FromName=StageZero

# ═══════════════════════════════════════════════════════════════
# LET'S ENCRYPT (TLS CERTIFICATES)
# ═══════════════════════════════════════════════════════════════
# Reverse-proxy hosts with "Use Let's Encrypt" enabled request certificates
# via the ACME HTTP-01 challenge. For validation to succeed the domain must be
# publicly resolvable and reach this app over HTTP at
#   http://<domain>/.well-known/acme-challenge/<token>
#
# Defaults to the Let's Encrypt STAGING environment (untrusted certs, generous
# rate limits) so you can test issuance safely. Set to true ONLY once issuance
# is verified — production has strict rate limits.
LetsEncrypt__UseProduction=false

# Example project with real SMTP data
# StageZero