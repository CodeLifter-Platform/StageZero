@using StageZero.Services.Dns
@using StageZero.Models
@inject ICloudflareService CloudflareService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudText Typo="Typo.h6" Class="mb-4">Add DNS Record for @Provider.Name</MudText>

            @if (!_loadedRecords)
            {
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           OnClick="LoadExistingRecords"
                           StartIcon="@Icons.Material.Filled.CloudDownload"
                           Class="mb-4"
                           FullWidth="true">
                    Load Existing Records from Cloudflare
                </MudButton>
            }

            @if (_loadingRecords)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Loading DNS records...</MudText>
            }

            @if (_cloudflareRecords.Count > 0)
            {
                <MudText Typo="Typo.body2" Class="mb-2">Select from existing records:</MudText>
                <MudSelect @bind-Value="_selectedCloudflareRecord"
                           Label="Existing DNS Records"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Class="mb-4"
                           T="CloudflareDnsRecord"
                           ToStringFunc="@(r => r != null ? $"{r.Name} ({r.Type}) - {r.Content}" : "")">
                    @foreach (var record in _cloudflareRecords.Where(r => r.Type == "A" || r.Type == "AAAA" || r.Type == "CNAME"))
                    {
                        <MudSelectItem Value="@record">@record.Name (@record.Type) - @record.Content</MudSelectItem>
                    }
                </MudSelect>

                <MudDivider Class="mb-4" />
                <MudText Typo="Typo.body2" Class="mb-2">Or enter manually:</MudText>
            }

            <MudTextField @bind-Value="_recordName"
                          Label="Record Name"
                          Required="true"
                          RequiredError="Record name is required"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-4"
                          HelperText="e.g., example.com or subdomain.example.com" />

            <MudSelect @bind-Value="_recordType"
                       Label="Record Type"
                       Required="true"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="mb-4">
                <MudSelectItem Value="@("A")">A (IPv4)</MudSelectItem>
                <MudSelectItem Value="@("AAAA")">AAAA (IPv6)</MudSelectItem>
                <MudSelectItem Value="@("CNAME")">CNAME (Alias)</MudSelectItem>
            </MudSelect>

            @if (_recordType == "CNAME")
            {
                <MudTextField @bind-Value="_content"
                              Label="CNAME Target"
                              Required="true"
                              RequiredError="CNAME target is required"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-4"
                              HelperText="The domain this CNAME should point to (e.g., target.example.com)" />
            }

            <MudCheckBox @bind-Value="_autoUpdate"
                         Label="Auto-update when IP changes"
                         Color="Color.Primary"
                         Disabled="@(_recordType == "CNAME")"
                         Class="mb-4" />

            @if (_recordType == "CNAME")
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    Note: CNAME records cannot be auto-updated with IP changes
                </MudText>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit"
                   Disabled="@(!_isValid)">
            Add Record
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public DnsProvider Provider { get; set; } = null!;

    private MudForm _form = null!;
    private bool _isValid;
    private string _recordName = string.Empty;
    private string _recordType = "A";
    private string _content = string.Empty;
    private bool _autoUpdate = true;
    private List<CloudflareDnsRecord> _cloudflareRecords = new();
    private CloudflareDnsRecord? _selectedCloudflareRecord;
    private bool _loadingRecords;
    private bool _loadedRecords;
    private string _errorMessage = string.Empty;

    protected override void OnParametersSet()
    {
        if (_selectedCloudflareRecord != null)
        {
            _recordName = _selectedCloudflareRecord.Name;
            _recordType = _selectedCloudflareRecord.Type;
            _content = _selectedCloudflareRecord.Content;

            // CNAME records should not auto-update
            if (_recordType == "CNAME")
            {
                _autoUpdate = false;
            }
        }
    }

    private async Task LoadExistingRecords()
    {
        try
        {
            _loadingRecords = true;
            _errorMessage = string.Empty;
            StateHasChanged();

            _cloudflareRecords = await CloudflareService.GetDnsRecordsAsync(Provider.ApiToken, Provider.ZoneId!);
            _loadedRecords = true;

            if (_cloudflareRecords.Count == 0)
            {
                Snackbar.Add("No DNS records found in Cloudflare", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load DNS records: {ex.Message}";
            Snackbar.Add(_errorMessage, Severity.Error);
        }
        finally
        {
            _loadingRecords = false;
            StateHasChanged();
        }
    }

    private void Submit()
    {
        if (!_isValid)
            return;

        // Validate CNAME has content
        if (_recordType == "CNAME" && string.IsNullOrWhiteSpace(_content))
        {
            _errorMessage = "CNAME target is required";
            return;
        }

        var result = new AddDnsRecordResult
        {
            RecordName = _recordName,
            RecordType = _recordType,
            AutoUpdate = _recordType != "CNAME" && _autoUpdate, // Force false for CNAME
            RecordId = _selectedCloudflareRecord?.Id,
            Content = _recordType == "CNAME" ? _content : null
        };

        MudDialog.Close(DialogResult.Ok(result));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}

