@using StageZero.Services.Auth
@inject IAuthService AuthService

<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            <MudText Typo="Typo.body1" Class="mb-2">
                <strong>Account Setup Required</strong>
            </MudText>
            <MudText Typo="Typo.body2">
                Please verify your email address and change your password to secure your account.
            </MudText>
        </MudAlert>

        @* Step Indicator *@
        <MudText Typo="Typo.h6" Class="mb-4">
            Step @(_currentStep) of 2: @(_currentStep == 1 ? "Email Verification" : "Change Password")
        </MudText>

        @if (_currentStep == 1)
        {
            @* Step 1: Email Verification *@
            <MudForm @ref="_emailForm" @bind-IsValid="@_emailFormValid">
                <MudTextField @bind-Value="Email"
                              Label="Email Address"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Required="true"
                              Immediate="true"
                              Class="mb-4"
                              Disabled="@_isLoading"
                              Validation="@(new Func<string, string?>(ValidateEmail))" />

                @if (!_codeSent)
                {
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               OnClick="SendVerificationCode"
                               Disabled="@(!_emailFormValid || _isLoading)"
                               FullWidth="true">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Sending Code...</span>
                        }
                        else
                        {
                            <span>Send Verification Code</span>
                        }
                    </MudButton>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Class="mb-4">
                        Verification code sent to @Email. Please check your inbox (or logs if email is not configured).
                    </MudAlert>

                    <MudTextField @bind-Value="VerificationCode"
                                  Label="Verification Code (6 digits)"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  Immediate="true"
                                  Class="mb-4"
                                  Disabled="@_isLoading"
                                  Validation="@(new Func<string, string?>(ValidateCode))" />

                    <MudButton Color="Color.Secondary"
                               Variant="Variant.Text"
                               OnClick="SendVerificationCode"
                               Disabled="@_isLoading"
                               Class="mb-2">
                        Resend Code
                    </MudButton>
                }
            </MudForm>
        }
        else
        {
            @* Step 2: Password Change *@
            <MudForm @ref="_passwordForm" @bind-IsValid="@_passwordFormValid">
                <MudTextField @bind-Value="CurrentPassword"
                              Label="Current Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Required="true"
                              Immediate="true"
                              Class="mb-4"
                              Disabled="@_isLoading" />

                <MudTextField @bind-Value="NewPassword"
                              Label="New Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Required="true"
                              Immediate="true"
                              Class="mb-4"
                              Disabled="@_isLoading"
                              Validation="@(new Func<string, string?>(ValidatePassword))" />

                <MudTextField @bind-Value="ConfirmPassword"
                              Label="Confirm New Password"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Required="true"
                              Immediate="true"
                              Class="mb-4"
                              Disabled="@_isLoading"
                              Validation="@(new Func<string, string?>(ValidateConfirmPassword))" />
            </MudForm>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">
                @_errorMessage
            </MudAlert>
        }

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">
                @_successMessage
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        @if (_currentStep == 1)
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="VerifyCode"
                       Disabled="@(!_codeSent || string.IsNullOrEmpty(VerificationCode) || _isLoading)">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Verifying...</span>
                }
                else
                {
                    <span>Verify & Continue</span>
                }
            </MudButton>
        }
        else
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="ChangePassword"
                       Disabled="@(!_passwordFormValid || _isLoading)">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Changing Password...</span>
                }
                else
                {
                    <span>Complete Setup</span>
                }
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    MudDialogInstance? MudDialog { get; set; }

    private MudForm? _emailForm;
    private MudForm? _passwordForm;
    private bool _emailFormValid;
    private bool _passwordFormValid;
    private bool _isLoading;
    private bool _codeSent;
    private int _currentStep = 1;
    private string? _errorMessage;
    private string? _successMessage;

    public string Email { get; set; } = string.Empty;
    public string VerificationCode { get; set; } = string.Empty;
    public string CurrentPassword { get; set; } = string.Empty;
    public string NewPassword { get; set; } = string.Empty;
    public string ConfirmPassword { get; set; } = string.Empty;

    private string? ValidateEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
            return "Email is required";

        if (!email.Contains("@") || !email.Contains("."))
            return "Please enter a valid email address";

        return null;
    }

    private string? ValidateCode(string code)
    {
        if (string.IsNullOrWhiteSpace(code))
            return "Verification code is required";

        if (code.Length != 6)
            return "Code must be 6 digits";

        return null;
    }

    private string? ValidatePassword(string password)
    {
        if (string.IsNullOrWhiteSpace(password))
            return "Password is required";

        if (password.Length < 6)
            return "Password must be at least 6 characters";

        return null;
    }

    private string? ValidateConfirmPassword(string confirmPassword)
    {
        if (string.IsNullOrWhiteSpace(confirmPassword))
            return "Please confirm your password";

        if (confirmPassword != NewPassword)
            return "Passwords do not match";

        return null;
    }

    private async Task SendVerificationCode()
    {
        _isLoading = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            await _emailForm!.Validate();

            if (!_emailFormValid)
            {
                _isLoading = false;
                return;
            }

            // Update email in database
            await AuthService.UpdateEmailAsync(Email);

            // Send verification code
            var success = await AuthService.SendEmailVerificationCodeAsync(Email);

            if (success)
            {
                _codeSent = true;
                _successMessage = "Verification code sent! Check your email.";
            }
            else
            {
                _errorMessage = "Failed to send verification code";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error sending code: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task VerifyCode()
    {
        _isLoading = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var success = await AuthService.VerifyEmailCodeAsync(VerificationCode);

            if (success)
            {
                _successMessage = "Email verified successfully!";
                await Task.Delay(500); // Brief pause to show success message
                _currentStep = 2; // Move to password change step
            }
            else
            {
                _errorMessage = "Invalid or expired verification code";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error verifying code: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ChangePassword()
    {
        _isLoading = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            await _passwordForm!.Validate();

            if (!_passwordFormValid)
            {
                _isLoading = false;
                return;
            }

            var success = await AuthService.ChangePasswordAsync(CurrentPassword, NewPassword);

            if (success)
            {
                _successMessage = "Password changed successfully!";
                await Task.Delay(500); // Brief pause to show success message
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                _errorMessage = "Current password is incorrect";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error changing password: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}

