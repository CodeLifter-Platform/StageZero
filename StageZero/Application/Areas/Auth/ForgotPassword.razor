@page "/forgot-password"
@using StageZero.Services.Auth
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Forgot Password - StageZero</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Class="mr-2" />
            Forgot Password
        </MudText>

        @if (!_codeSent)
        {
            <MudText Typo="Typo.body1" Class="mb-4">
                Enter your email address and we'll send you a code to reset your password.
            </MudText>

            <MudForm @ref="_form" @bind-IsValid="@_isValid">
                <MudTextField @bind-Value="_email"
                              Label="Email Address"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Email is required"
                              InputType="InputType.Email"
                              Validation="@(new System.ComponentModel.DataAnnotations.EmailAddressAttribute())"
                              Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="SendResetCode"
                           Disabled="@(!_isValid || _isLoading)"
                           Class="mb-4">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send Reset Code</span>
                    }
                </MudButton>
            </MudForm>

            <MudDivider Class="my-4" />

            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="@(() => Navigation.NavigateTo("/login"))">
                Back to Login
            </MudButton>
        }
        else
        {
            <MudAlert Severity="Severity.Success" Class="mb-4">
                A password reset code has been sent to your email address.
            </MudAlert>

            <MudText Typo="Typo.body1" Class="mb-4">
                Please check your email and enter the 6-digit code below to reset your password.
            </MudText>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="GoToResetPassword"
                       Class="mb-4">
                Enter Reset Code
            </MudButton>

            <MudButton Variant="Variant.Text"
                       Color="Color.Secondary"
                       FullWidth="true"
                       OnClick="ResendCode"
                       Disabled="@_isLoading">
                Resend Code
            </MudButton>
        }
    </MudPaper>
</MudContainer>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _isLoading;
    private bool _codeSent;
    private string _email = string.Empty;

    private async Task SendResetCode()
    {
        if (_form == null || !_isValid)
            return;

        _isLoading = true;
        try
        {
            var success = await AuthService.SendPasswordResetCodeAsync(_email);
            if (success)
            {
                _codeSent = true;
                Snackbar.Add("Password reset code sent to your email", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to send reset code. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ResendCode()
    {
        await SendResetCode();
    }

    private void GoToResetPassword()
    {
        Navigation.NavigateTo($"/reset-password?email={Uri.EscapeDataString(_email)}");
    }
}

