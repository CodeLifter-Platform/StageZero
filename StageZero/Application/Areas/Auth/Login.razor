@page "/login"
@using StageZero.Services.Auth
@using StageZero.DataAdapters.Users
@inject IAuthService AuthService
@inject IUserReader UserReader
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Login - StageZero</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Class="mr-2" />
            StageZero Login
        </MudText>

        <EditForm Model="@_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_model.Email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Required="true"
                          Immediate="true"
                          Class="mb-4"
                          Disabled="@_isLoading" />

            <MudTextField @bind-Value="_model.Password"
                          Label="Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Required="true"
                          Immediate="true"
                          Class="mb-6"
                          Disabled="@_isLoading" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Logging in...</span>
                }
                else
                {
                    <span>Login</span>
                }
            </MudButton>
        </EditForm>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">
                @_errorMessage
            </MudAlert>
        }

        <MudDivider Class="my-4" />

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="@(() => Navigation.NavigateTo("/forgot-password"))">
            Forgot Password?
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private LoginModel _model = new();
    private bool _isLoading = false;
    private string? _errorMessage;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Check if setup is needed
        var users = await UserReader.GetAllAsync();
        if (!users.Any())
        {
            Navigation.NavigateTo("/setup");
        }
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await AuthService.LoginAsync(_model.Email, _model.Password);

            if (result.Success)
            {
                Snackbar.Add($"Welcome!", Severity.Success);

                // Check if account setup is required (password change or email verification)
                var requiresPasswordChange = AuthService.RequiresPasswordChange;
                var requiresEmailVerification = AuthService.RequiresEmailVerification;

                if (requiresPasswordChange || requiresEmailVerification)
                {
                    await ShowSetupDialog();
                }
                else
                {
                    // Redirect to return URL or home
                    var redirectUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
                    Navigation.NavigateTo(redirectUrl);
                }
            }
            else
            {
                _errorMessage = result.ErrorMessage ?? "Login failed";
            }
        }
        catch (Exception)
        {
            _errorMessage = "An error occurred during login. Please try again.";
            Snackbar.Add("Login error", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ShowSetupDialog()
    {
        var options = new DialogOptions
        {
            CloseButton = false,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ChangePasswordDialog>("Account Setup", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            Snackbar.Add("Account setup completed successfully!", Severity.Success);

            // Redirect to return URL or home
            var redirectUrl = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
            Navigation.NavigateTo(redirectUrl);
        }
        else
        {
            // User canceled - log them out
            await AuthService.LogoutAsync();
            _errorMessage = "Account setup is required to continue";
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}

