@page "/reset-password"
@using StageZero.Services.Auth
@using Microsoft.AspNetCore.WebUtilities
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Reset Password - StageZero</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Class="mr-2" />
            Reset Password
        </MudText>

        <MudText Typo="Typo.body1" Class="mb-4">
            Enter the 6-digit code sent to your email and your new password.
        </MudText>

        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudTextField @bind-Value="_email"
                          Label="Email Address"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Email is required"
                          InputType="InputType.Email"
                          Class="mb-4" />

            <MudTextField @bind-Value="_code"
                          Label="6-Digit Code"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Code is required"
                          MaxLength="6"
                          HelperText="Enter the 6-digit code from your email"
                          Class="mb-4" />

            <MudTextField @bind-Value="_newPassword"
                          Label="New Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Required="true"
                          RequiredError="Password is required"
                          HelperText="Minimum 8 characters"
                          Class="mb-4" />

            <MudTextField @bind-Value="_confirmPassword"
                          Label="Confirm New Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Required="true"
                          RequiredError="Please confirm your password"
                          Validation="@(new Func<string, string?>(ValidateConfirmPassword))"
                          Class="mb-4" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="ResetPasswordAsync"
                       Disabled="@(!_isValid || _isLoading)"
                       Class="mb-4">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Resetting...</span>
                }
                else
                {
                    <span>Reset Password</span>
                }
            </MudButton>
        </MudForm>

        <MudDivider Class="my-4" />

        <MudButton Variant="Variant.Text"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="@(() => Navigation.NavigateTo("/forgot-password"))">
            Back to Forgot Password
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _isLoading;
    private string _email = string.Empty;
    private string _code = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    protected override void OnInitialized()
    {
        // Get email from query string if provided
        var uri = new Uri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("email", out var email))
        {
            _email = email.ToString();
        }
    }

    private string? ValidateConfirmPassword(string confirmPassword)
    {
        if (string.IsNullOrEmpty(confirmPassword))
            return "Please confirm your password";

        if (confirmPassword != _newPassword)
            return "Passwords do not match";

        return null;
    }

    private async Task ResetPasswordAsync()
    {
        if (_form == null || !_isValid)
            return;

        if (_newPassword.Length < 8)
        {
            Snackbar.Add("Password must be at least 8 characters long", Severity.Error);
            return;
        }

        _isLoading = true;
        try
        {
            var success = await AuthService.ResetPasswordAsync(_email, _code, _newPassword);
            if (success)
            {
                Snackbar.Add("Password reset successfully! You'll need to verify your email on next login.", Severity.Success);
                await Task.Delay(2000);
                Navigation.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add("Invalid or expired code. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}

